# Video Note Bot Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Telegram Bot Token (required)
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here


# =============================================================================
# LOCAL BOT API SERVER (optional — for files > 50MB)
# =============================================================================

# Enable self-hosted telegram-bot-api server instead of api.telegram.org.
# Requires running telegram-bot-api with --local flag.
# Docs: https://github.com/tdlib/telegram-bot-api
# TELEGRAM_LOCAL_MODE=true

# Base URL of your local Bot API server (must end with /bot)
# Example: http://127.0.0.1:8081/bot
# TELEGRAM_API_BASE_URL=http://127.0.0.1:8081/bot

# Networking timeouts (seconds) for local API file transfers
# TELEGRAM_API_TIMEOUT=30

# Max upload size in MB (50 cloud default, up to 2000 with local API)
# TELEGRAM_MAX_UPLOAD_SIZE_MB=2000

# Incoming file limits for user uploads (videos, audio, images).
# With TELEGRAM_LOCAL_MODE=true these default to TELEGRAM_MAX_UPLOAD_SIZE_MB.
# MAX_FILE_SIZE_MB=2000
# MAX_AUDIO_FILE_SIZE_MB=2000

# Max download size in MB (500 cloud with auto-split, up to 2000 local)
# DOWNLOAD_MAX_SIZE_MB=2000
# DOWNLOAD_MAX_SIZE_GENERIC_MB=2000

# Credentials for self-hosted telegram-bot-api (https://my.telegram.org)
# Required for docker-compose and Railway telegram-bot-api service.
# TELEGRAM_API_ID=your_api_id
# TELEGRAM_API_HASH=your_api_hash


# =============================================================================
# DOCKER COMPOSE (local stack: bot + telegram-bot-api)
# =============================================================================
#
# 1. Copy this file to .env and set BOT_TOKEN + TELEGRAM_API_ID + TELEGRAM_API_HASH
# 2. Run: docker compose up --build
#
# The bot container starts telegram-bot-api and the bot together on localhost:8081.


# =============================================================================
# RAILWAY DEPLOY
# =============================================================================
#
# After pushing code, run:
#   TELEGRAM_API_ID=... TELEGRAM_API_HASH=... ./scripts/setup-railway-local-api.sh
#
# Railway bot service variables (set automatically by the script):
#   TELEGRAM_LOCAL_MODE=true
#   TELEGRAM_API_BASE_URL=http://${{telegram-bot-api.RAILWAY_PRIVATE_DOMAIN}}:${{telegram-bot-api.PORT}}/bot
#   TELEGRAM_MAX_UPLOAD_SIZE_MB=2000
#   DOWNLOAD_MAX_SIZE_MB=2000


# =============================================================================
# TIMEOUTS (seconds)
# =============================================================================

# Timeout for standard video processing operations (convert, extract audio, split)
PROCESSING_TIMEOUT=60

# Timeout for video download operations
DOWNLOAD_TIMEOUT=60

# Timeout for video join operations (joining multiple videos)
JOIN_TIMEOUT=120

# Session timeout for join command (how long to wait for more videos)
JOIN_SESSION_TIMEOUT=300


# =============================================================================
# LIMITS
# =============================================================================

# Maximum file size in MB that the bot will accept
MAX_FILE_SIZE_MB=20

# Maximum number of segments when splitting videos
MAX_SEGMENTS=10

# Minimum duration in seconds for each video segment
MIN_SEGMENT_SECONDS=5

# Maximum number of videos that can be joined in one operation
JOIN_MAX_VIDEOS=10

# Minimum number of videos required for join operation
JOIN_MIN_VIDEOS=2


# =============================================================================
# LOGGING
# =============================================================================

# Logging level for the bot
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# =============================================================================
# OPTIONAL PATHS
# =============================================================================

# Custom temporary directory for file processing
# If not set, uses system default temp directory
# TEMP_DIR=/tmp
